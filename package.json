{
  "name": "sveltesse",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "husky": "husky",
    "dev": "vite dev",
    "build": "wrangler types --check && vite build",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "deploy:dev": "pnpm run build && wrangler --env dev deploy",
    "deploy:prod": "pnpm run build --mode prod && wrangler --env prod deploy",
    "secret:bulk:dev": "wrangler --env dev secret bulk .env.local",
    "secret:bulk:prod": "wrangler --env prod secret bulk .env.prod",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "doctor": "pnpm dlx svelte-doctor check",
    "check": "pnpm dlx svelte-check-rs",
    "check:watch": "pnpm dlx svelte-check-rs --watch",
    "gen": "wrangler types"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "wrangler": "^4.85.0"
  }
}
